/*
 * Configuration Template for HopFog ESP32-CAM
 * 
 * INSTRUCTIONS:
 * 1. Copy this file to config.h
 * 2. Edit config.h with your actual credentials
 * 3. Add config.h to .gitignore to avoid committing credentials
 * 
 * For quick start, you can also edit credentials directly in
 * esp32_hopfog.ino (not recommended for production).
 */

// WiFi Configuration
#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Admin Credentials
// IMPORTANT: Change these before deploying!
#define ADMIN_USERNAME "admin"
#define ADMIN_PASSWORD "admin123"

// Optional: Web Server Port (default: 80)
// #define WEB_SERVER_PORT 80

// Optional: Camera Quality (1-63, lower is better quality)
// #define CAMERA_QUALITY 10

// Optional: Camera Frame Size
// Options: FRAMESIZE_QQVGA, FRAMESIZE_QVGA, FRAMESIZE_VGA, FRAMESIZE_SVGA, FRAMESIZE_XGA, FRAMESIZE_SXGA, FRAMESIZE_UXGA
// #define CAMERA_FRAME_SIZE FRAMESIZE_SVGA
