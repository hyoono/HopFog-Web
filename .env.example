# HopFog-Web Environment Configuration
# Copy this file to .env and update with your values
# DO NOT commit .env file to version control

# ======================
# Database Configuration
# ======================

# SQLite (Development)
DATABASE_URL=sqlite:///./capstone.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://username:password@localhost/database_name

# MySQL (Alternative)
# DATABASE_URL=mysql+pymysql://username:password@localhost/database_name

# ======================
# Security Configuration
# ======================

# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING

# JWT Algorithm
ALGORITHM=HS256

# Token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ======================
# Application Settings
# ======================

# Debug mode (set to False in production)
DEBUG=False

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Application URL
APP_URL=http://localhost:8000

# ======================
# CORS Settings
# ======================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ======================
# Email Configuration (Optional)
# ======================

# SMTP settings for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ======================
# External Services (Optional)
# ======================

# Redis (for caching)
# REDIS_URL=redis://localhost:6379/0

# ======================
# Logging Configuration
# ======================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/hopfog.log

# ======================
# ESP32-CAM Integration (Optional)
# ======================

# ESP32-CAM device URLs (comma-separated)
# ESP32_DEVICES=http://192.168.1.100,http://192.168.1.101
